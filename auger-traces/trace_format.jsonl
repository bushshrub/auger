// Sample Auger trace format

// Every session will start with this
{
  "type": "session",
  "version": 1, // Denotes the version of the trace format.
  "session_id": "8c29418f-c535-4ad4-ab2f-2eed8dfd7f28", // UUIDv4 session ID. should we change to v7?
  "created_at": "2026-07-13T22:30:00Z",
  "cwd": "/repo", // absolute path to the working directory of the session
  // model details. might need to change up the format depending on our code later
  "model": {
    "provider": "openai",
    "id": "gpt-5.6"
  }
}
// The first message in a session must always start with the user message.
{
  "type": "user_message",
  "id": "019f5e78-35a8-7472-8733-e396332c066e", // UUIDv7 message ID.
  "parent_id": null, // the parent UUID. First message = null. All subsequent messages will have a parent UUID.
  "seq": 1, // The order of the event in the session. The first event = 1, second = 2, etc.
  "timestamp": "2026-07-13T22:30:02Z",
  "content": [
    {
      "type": "text",
      "text": "Fix the tests now"
    }
    // we will support image in the future probably
  ]
}
{
  "type": "assistant_message",
  "id": "019f5e78-6f24-7c39-bfa1-82de286b5544",
  // the logical parent. in this case the assistant message was a direct result of the user sending a message.
  "parent_id": "019f5e78-35a8-7472-8733-e396332c066e",
  "seq": 2,
  "timestamp": "2026-07-13T22:30:02Z",
  "status": "completed", // or interrupted/failed depending on what happened
  "content": [
    {
      "type": "reasoning",
      "text": "I should inspect the failing test before changing the implementation"
    },
    {
      "type": "text",
      "text": "I will inspect the current test failures"
    },
    {
      "type": "tool_call",
      "id": "call_123",
      "name": "shell",
      "arguments": {
        "command": "cargo test failing_test -- --nocapture"
      }
    },
    {
      "type": "tool_call",
      "id": "call_456",
      "name": "shell",
      "arguments": {
        "command": "head -n 40 agent-core/src/session.rs"
      }
    }
  ],
  // Optional field I think. Not sure how this will evolve?. May not even be in the first iteration of this
  "provider_metadata": {
    "stop_reason": "max_tokens"
  }
}

// Automated tool authorization also gets logged.
{
  "id": "019f5e80-c5b7-78d4-8631-bebe5b2405d6",
  "seq": 3,
  // Note that parent id refers to the logical cause of the tool call, which is the assistant message.
  "parent_id": "019f5e78-6f24-7c39-bfa1-82de286b5544",
  "type": "tool_authorization",
  "tool_call_id": "call_123",
  "decision": "approved",
  "source": "policy", // or user. policy = automated decision
  "reason": null // optional string value. if user provided a reason.
}

{
  "id": "019f5e80-ea22-7e9c-b35c-4f250d7424bf",
  // seq here controls the physical append order of the events in the session.
  "seq": 4,
  "parent_id": "019f5e78-6f24-7c39-bfa1-82de286b5544",
  "type": "tool_authorization",
  "tool_call_id": "call_456",
  "decision": "denied",
  "source": "user", // or user. policy = automated decision
  "reason": "That file does not contain that issue" // optional string value. if user provided a reason.
}

// call_123 was authorized and executed successfully.
{
  "type": "tool_result",
  "id": "019f5e85-d865-74d6-9c22-855a6b804b7f",
  // The authorization event caused this result to be produced.
  "parent_id": "019f5e80-c5b7-78d4-8631-bebe5b2405d6",
  "seq": 5,
  "timestamp": "2026-07-13T22:30:08Z",
  "tool_call_id": "call_123",
  "status": "success",
  "content": [
    {
      "type": "text",
      "text": "running 1 test\ntest failing_test ... ok\n\ntest result: ok. 1 passed; 0 failed"
    }
  ]
}

// call_456 was denied and therefore never executed.
// The harness still sends a tool result back to the model so that
// the tool call is resolved in the conversation protocol.
{
  "type": "tool_result",
  "id": "019f5e86-8826-7138-aa75-33d0b9ac02a7",
  "parent_id": "019f5e80-ea22-7e9c-b35c-4f250d7424bf",
  "seq": 6,
  "timestamp": "2026-07-13T22:30:08Z",
  "tool_call_id": "call_456",
  "status": "denied",
  "content": [
    {
      "type": "text",
      "text": "Tool execution was denied by the user: That file does not contain that issue"
    }
  ]
}
// The assistant receives both prior tool results and decides it needs to
// inspect two additional files.
{
  "type": "assistant_message",
  "id": "019f5e88-0c8e-749c-a9fc-f620afc78f5a",
  // For a linear v1 trace, point this at the last physically appended result.
  // The assistant response logically depends on both call_123 and call_456.
  "parent_id": "019f5e86-8826-7138-aa75-33d0b9ac02a7",
  "seq": 7,
  "timestamp": "2026-07-13T22:30:10Z",
  "status": "completed",
  "content": [
    {
      "type": "reasoning",
      "text": "The requested test passes, but the denied command means I still need to inspect the relevant implementation and test files directly."
    },
    {
      "type": "text",
      "text": "I will inspect the implementation and the corresponding test."
    },
    {
      "type": "tool_call",
      "id": "call_789",
      "name": "read_file",
      "arguments": {
        "path": "agent-core/src/session.rs"
      }
    },
    {
      "type": "tool_call",
      "id": "call_987",
      "name": "read_file",
      "arguments": {
        "path": "agent-core/tests/session_tests.rs"
      }
    }
  ]
}

// Both read_file calls are automatically authorized by policy.
// They share the same logical parent because both decisions were caused
// independently by the same assistant message.
{
  "type": "tool_authorization",
  "id": "019f5e88-3316-7952-baaa-c62fc1fb8391",
  "parent_id": "019f5e88-0c8e-749c-a9fc-f620afc78f5a",
  "seq": 8,
  "timestamp": "2026-07-13T22:30:10Z",
  "tool_call_id": "call_789",
  "decision": "approved",
  "source": "policy",
  "reason": null
}

{
  "type": "tool_authorization",
  "id": "019f5e88-49c0-71cc-b00c-bd34ed25112f",
  "parent_id": "019f5e88-0c8e-749c-a9fc-f620afc78f5a",
  "seq": 9,
  "timestamp": "2026-07-13T22:30:10Z",
  "tool_call_id": "call_987",
  "decision": "approved",
  "source": "policy",
  "reason": null
}

// The harness executes both calls and records the results.
// These are protocol tool-result messages sent back to the model.
// They are not user messages because the human did not author them.
{
  "type": "tool_result",
  "id": "019f5e89-1057-795f-8313-67e76cdcc52e",
  "parent_id": "019f5e88-3316-7952-baaa-c62fc1fb8391",
  "seq": 10,
  "timestamp": "2026-07-13T22:30:11Z",
  "tool_call_id": "call_789",
  "status": "success",
  "content": [
    {
      "type": "text",
      "text": "use crate::events::{HarnessState, LoopMessage, SessionCommand, SessionEvent};\nuse auger_driver::{StreamResult, TypedAgent, WaitingForUserMessage};\n\npub struct Session {\n    id: SessionId,\n    cmd_rx: mpsc::Receiver<LoopMessage>,\n    event_tx: mpsc::Sender<SessionEvent>,\n    // ...\n}"
    }
  ]
}

{
  "type": "tool_result",
  "id": "019f5e89-2ee1-73a0-a7e8-d49d3ec01206",
  "parent_id": "019f5e88-49c0-71cc-b00c-bd34ed25112f",
  "seq": 11,
  "timestamp": "2026-07-13T22:30:11Z",
  "tool_call_id": "call_987",
  "status": "success",
  "content": [
    {
      "type": "text",
      "text": "#[test]\nfn restored_session_accepts_new_user_message() {\n    // ...\n}\n\n#[test]\nfn interrupted_session_preserves_committed_history() {\n    // ...\n}"
    }
  ]
}

// The assistant receives both tool results and continues the turn.
{
  "type": "assistant_message",
  "id": "019f5e8a-0ef3-7dae-a404-3a8aa2fdb6ca",
  // In the linear v1 format, point to the last appended tool result.
  // The response semantically depends on both tool results.
  "parent_id": "019f5e89-2ee1-73a0-a7e8-d49d3ec01206",
  "seq": 12,
  "timestamp": "2026-07-13T22:30:13Z",
  "status": "completed",
  "content": [
    {
      "type": "reasoning",
      "text": "The session implementation updates the committed snapshot before starting the stream, while the tests only cover restoration at a user-input boundary. The missing behavior is likely in how interrupted assistant output is committed before restoration."
    },
    {
      "type": "text",
      "text": "The relevant issue appears to be in the interrupted-stream commit path rather than the normal restore path. The session records the user message before streaming, but the tests do not verify that partial assistant output is committed before an interrupted session is restored."
    }
  ]
}